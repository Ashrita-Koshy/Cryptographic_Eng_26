// ============================================================
// Run all fixed tests at once
// ============================================================
allTests : Bool
allTests = BitsToBytes_Example_1 /\ BitsToBytes_Example_2 /\ BitsToBytes_Example_3
            /\ BitsToBytes_Example_4 /\ BitsToBytes_Example_5
            /\ BitsToBytes_Example_6 /\ BitsToBytes_Example_7 
            /\ BitsToBytes_Example_8 /\ BitsToBytes_Example_9 
            /\ BitsToBytes_Example_10 /\ BitsToBytes_Example_11 
            /\ BitsToBytes_Example_12 /\ BitsToBytes_Example_13 
            /\ BitsToBytes_Example_14 /\ BitsToBytes_Example_15

